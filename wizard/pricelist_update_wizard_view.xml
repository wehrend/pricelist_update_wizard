<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pricelist_update_wizard_form" model="ir.ui.view">
        <field name="name">product.pricelist.update.wizard.form</field>
        <field name="model">product.pricelist.update.wizard</field>
        <field name="arch" type="xml">
            <form string="Pricelist Update">
                <sheet> <group>
                        <field name="update_type"/>
                        <field name="value"/>
                    </group>
                    <footer>
                        <button string="Update Prices" name="action_apply_pricelist_update" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_pricelist_update_wizard" model="ir.actions.act_window">
    <field name="name">Bulk Update Prices</field>
    <field name="res_model">product.pricelist.update.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="binding_model_id" ref="product.model_product_pricelist"/>
    <field name="binding_view_types">list,form</field>
</record>
</odoo>